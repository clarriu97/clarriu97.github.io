---
import ChatIcon from "./icons/Chat.astro"

// Floating "ask about Carlos" chat. Talks to the Cloudflare Worker (see worker/).
// Default points at the deployed *.workers.dev URL, which already allows both
// https://larri.dev (prod) and http://localhost:4321 (dev) in its CORS config
// (see worker/wrangler.toml ALLOWED_ORIGINS) — so this works in both places
// with zero extra config. Override with PUBLIC_CHAT_ENDPOINT in a local .env
// (gitignored) to point at a locally-running `wrangler dev` instead, or once
// a custom domain like chat.larri.dev is set up, update the fallback below.
const endpoint =
  import.meta.env.PUBLIC_CHAT_ENDPOINT || "https://larri-chat.larridev.workers.dev/chat"

// Turnstile (guardrail Layer B — proves a real browser, not a script, is
// calling the Worker). The widget is configured for both larri.dev (prod) and
// localhost (dev) hostnames, so this one key works in both places, same as
// the endpoint above. Override with PUBLIC_TURNSTILE_SITE_KEY if you ever
// need to point at a different widget (e.g. a staging one).
const turnstileSiteKey =
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "0x4AAAAAAD6oU7E2Q9VJxwWm"
---

<button
  id="chat-launcher"
  class="chat-launcher"
  type="button"
  aria-label="Chat with an AI assistant about Carlos"
  aria-expanded="false"
>
  <span class="chat-launcher-icon" aria-hidden="true">
    <ChatIcon class="chat-launcher-glyph" />
    <span class="chat-launcher-dot"></span>
  </span>
  <span class="chat-launcher-label">Ask AI about Carlos</span>
</button>

<div
  id="chat-panel"
  class="chat-panel"
  data-endpoint={endpoint}
  data-turnstile-sitekey={turnstileSiteKey}
  hidden
  role="dialog"
  aria-label="Ask about Carlos"
>
  <div class="chat-bar">
    <span class="dot dot-red" aria-hidden="true"></span>
    <span class="dot dot-amber" aria-hidden="true"></span>
    <span class="dot dot-green" aria-hidden="true"></span>
    <span class="chat-title font-mono">ask@larri.dev: ~</span>
    <button id="chat-clear" class="chat-tool" type="button" title="Clear conversation">
      clear
    </button>
    <button id="chat-close" class="chat-tool" type="button" aria-label="Close chat">
      esc
    </button>
  </div>

  <div id="chat-log" class="chat-log" aria-live="polite" aria-atomic="false"></div>

  <form id="chat-form" class="chat-form">
    <span class="chat-prompt font-mono" aria-hidden="true">&#10095;</span>
    <textarea
      id="chat-input"
      class="chat-input font-mono"
      rows="1"
      placeholder="Ask me about Carlos…"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
      aria-label="Message"></textarea>
    <button id="chat-send" class="chat-send" type="submit" aria-label="Send">
      send
    </button>
  </form>

  <!-- Managed mode stays invisible for most visitors; only shows a checkbox
       to ones Cloudflare flags as risky, rendered right here if so. -->
  <div id="chat-turnstile" class="chat-turnstile"></div>
</div>

<style is:global>
  /*
   * is:global is required here: chat bubbles/labels are created client-side
   * with document.createElement(), so they never receive Astro's per-component
   * scoping attribute. Scoped selectors would silently never match them.
   */
  /*
   * Deliberately placed at bottom-LEFT, away from the search/Cmd+K launcher
   * (bottom-right) — two stacked floating buttons in the same corner read as
   * one menu and blur the fact that this one opens an AI chat, not search.
   */
  .chat-launcher {
    position: fixed;
    bottom: 1.25rem;
    left: 1.25rem;
    z-index: 45;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.5rem 0.9rem 0.5rem 0.5rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--surface) 80%, transparent);
    border: 1px solid var(--border);
    color: var(--muted);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, transform 0.2s;
  }
  .chat-launcher:hover {
    color: var(--text);
    border-color: var(--accent-soft);
    transform: translateY(-1px);
  }
  .chat-launcher-icon {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 9999px;
    background: var(--accent-soft);
    color: var(--accent);
    flex-shrink: 0;
  }
  .chat-launcher-glyph {
    width: 1.05rem;
    height: 1.05rem;
  }
  .chat-launcher-dot {
    position: absolute;
    bottom: -0.05rem;
    right: -0.05rem;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 9999px;
    background: #28c840;
    border: 2px solid var(--surface);
    animation: chat-dot-pulse 2.4s ease-in-out infinite;
  }
  @keyframes chat-dot-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.25); opacity: 0.75; }
  }
  .chat-launcher-label {
    font-size: 0.85rem;
    font-weight: 500;
  }

  .chat-panel {
    position: fixed;
    bottom: 1.25rem;
    left: 1.25rem;
    z-index: 55;
    display: flex;
    flex-direction: column;
    width: min(380px, calc(100vw - 2rem));
    height: min(72vh, 560px);
    background: color-mix(in srgb, var(--surface) 92%, transparent);
    border: 1px solid var(--border);
    border-radius: 16px;
    box-shadow: 0 30px 80px -20px rgba(0, 0, 0, 0.6);
    overflow: hidden;
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    animation: chat-in 0.16s ease-out;
  }
  .chat-panel[hidden] {
    display: none;
  }
  @keyframes chat-in {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .chat-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 0.85rem;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface-2) 55%, transparent);
  }
  .dot {
    display: inline-block;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 9999px;
  }
  .dot-red { background: #ff5f57; }
  .dot-amber { background: #febc2e; }
  .dot-green { background: #28c840; }
  .chat-title {
    flex: 1;
    margin-left: 0.4rem;
    font-size: 0.76rem;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .chat-tool {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.7rem;
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.1rem 0.4rem;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .chat-tool:hover {
    color: var(--text);
    border-color: var(--accent-soft);
  }

  .chat-log {
    flex: 1;
    overflow-y: auto;
    padding: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .chat-hint {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .chat-msg {
    max-width: 85%;
    padding: 0.5rem 0.7rem;
    border-radius: 12px;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .chat-text {
    word-break: break-word;
  }
  /* User text is plain (textContent) — preserve their own line breaks/spacing. */
  .chat-user .chat-text {
    white-space: pre-wrap;
  }
  /* Assistant text is rendered markdown (real <p>/<ul>/<a> elements). */
  .chat-assistant .chat-text p {
    margin: 0 0 0.6em;
  }
  .chat-assistant .chat-text p:last-child {
    margin-bottom: 0;
  }
  .chat-assistant .chat-text ul {
    margin: 0 0 0.6em;
    padding-left: 1.2em;
  }
  .chat-assistant .chat-text ul:last-child {
    margin-bottom: 0;
  }
  .chat-assistant .chat-text li {
    margin-bottom: 0.2em;
  }
  .chat-assistant .chat-text a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
  .chat-assistant .chat-text strong {
    font-weight: 700;
  }
  .chat-role {
    display: block;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.2rem;
  }
  .chat-user {
    align-self: flex-end;
    background: color-mix(in srgb, var(--accent) 20%, var(--surface-2));
    color: var(--text);
    border: 1px solid var(--accent-soft);
  }
  .chat-user .chat-role {
    text-align: right;
    color: var(--accent);
  }
  .chat-assistant {
    align-self: flex-start;
    background: var(--surface-2);
    color: var(--text);
    border: 1px solid var(--border);
  }
  .chat-assistant .chat-role {
    text-align: left;
    color: var(--muted);
  }
  .chat-assistant.is-streaming .chat-text::after {
    content: "";
    display: inline-block;
    width: 0.5ch;
    height: 1em;
    margin-left: 0.1em;
    vertical-align: -0.15em;
    background-color: var(--accent);
    animation: chat-caret 1s step-end infinite;
  }
  @keyframes chat-caret {
    from, to { opacity: 1; }
    50% { opacity: 0; }
  }

  .chat-form {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    padding: 0.7rem 0.85rem;
    border-top: 1px solid var(--border);
  }
  /* Empty for the vast majority of visitors (Managed mode auto-passes them
     silently). Only occupies space if Cloudflare shows a challenge box. */
  .chat-turnstile:not(:empty) {
    padding: 0 0.85rem 0.7rem;
  }
  .chat-prompt {
    color: var(--accent);
    font-weight: 700;
    padding-bottom: 0.35rem;
  }
  .chat-input {
    flex: 1;
    min-width: 0;
    resize: none;
    max-height: 6rem;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .chat-input::placeholder {
    color: var(--muted);
  }
  .chat-send {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
    color: var(--text);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.35rem 0.6rem;
    cursor: pointer;
    transition: border-color 0.2s, opacity 0.2s;
  }
  .chat-send:hover {
    border-color: var(--accent-soft);
  }
  .chat-send:disabled {
    opacity: 0.5;
    cursor: default;
  }

  @media (max-width: 480px) {
    .chat-launcher-label { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .chat-panel { animation: none; }
    .chat-launcher { transition: none; }
    .chat-launcher-dot { animation: none; }
    .chat-assistant.is-streaming .chat-text::after { animation: none; }
  }
</style>

<script>
  type Msg = { role: "user" | "assistant"; content: string }

  const ANON_KEY = "larri.chat.anonId"
  const LOG_KEY = "larri.chat.transcript"
  const GREETING =
    "Hi — ask me anything about Carlos: his work, projects, or how to reach him."

  // --- Minimal markdown renderer for assistant replies -----------------
  // Narrow on purpose: bold, http(s) links, and "- "/"* " bullet lists — the
  // only markdown the model actually produces. Always escape first so any
  // raw HTML/URLs from the model can't inject tags or break out of
  // attributes; only http(s) links are linkified (no javascript:/data: etc).
  const escapeHtml = (s: string): string =>
    s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;")

  const renderInline = (s: string): string =>
    s
      .replace(
        /\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g,
        (_m, text, url) => `<a href="${url}" target="_blank" rel="noopener noreferrer">${text}</a>`,
      )
      .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")

  const renderMarkdown = (raw: string): string => {
    const lines = escapeHtml(raw).split("\n")
    const parts: string[] = []
    let list: string[] = []
    let para: string[] = []

    const flushList = () => {
      if (list.length) {
        parts.push(`<ul>${list.map((item) => `<li>${renderInline(item)}</li>`).join("")}</ul>`)
        list = []
      }
    }
    const flushPara = () => {
      if (para.length) {
        parts.push(`<p>${para.map(renderInline).join("<br>")}</p>`)
        para = []
      }
    }

    for (const line of lines) {
      const trimmed = line.trim()
      const listItem = /^[-*]\s+(.*)$/.exec(trimmed)
      if (listItem) {
        flushPara()
        list.push(listItem[1])
      } else if (trimmed === "") {
        flushList()
        flushPara()
      } else {
        flushList()
        para.push(trimmed)
      }
    }
    flushList()
    flushPara()
    return parts.join("")
  }

  type Controller = { open: () => void; close: () => void; toggle: () => void }
  let controller: Controller | null = null

  // --- Turnstile (guardrail Layer B: proves a real browser, not a script) ---
  interface TurnstileRenderOptions {
    sitekey: string
    size?: "normal" | "compact" | "flexible"
    callback?: (token: string) => void
    "expired-callback"?: () => void
    "error-callback"?: () => void
  }
  interface TurnstileApi {
    render: (container: string | HTMLElement, options: TurnstileRenderOptions) => string
    reset: (widgetId?: string) => void
  }
  declare global {
    interface Window {
      turnstile?: TurnstileApi
    }
  }

  let turnstileScriptPromise: Promise<void> | null = null
  const loadTurnstileScript = (): Promise<void> => {
    if (turnstileScriptPromise) return turnstileScriptPromise
    turnstileScriptPromise = new Promise((resolve) => {
      if (window.turnstile) return resolve()
      const script = document.createElement("script")
      script.src = "https://challenges.cloudflare.com/turnstile/v0/api.js"
      script.async = true
      script.defer = true
      script.addEventListener("load", () => resolve())
      document.head.appendChild(script)
    })
    return turnstileScriptPromise
  }

  // Bound once for the page lifetime (Cmd+K palette dispatches this on window).
  window.addEventListener("larri:open-chat", () => controller?.open())

  const initChatAgent = () => {
    const launcher = document.getElementById("chat-launcher")
    const panel = document.getElementById("chat-panel")
    const log = document.getElementById("chat-log")
    const form = document.getElementById("chat-form")
    const input = document.getElementById("chat-input") as HTMLTextAreaElement | null
    const sendBtn = document.getElementById("chat-send") as HTMLButtonElement | null
    const clearBtn = document.getElementById("chat-clear")
    const closeBtn = document.getElementById("chat-close")
    const turnstileContainer = document.getElementById("chat-turnstile")
    if (!launcher || !panel || !log || !form || !input || !sendBtn) return

    const endpoint = panel.dataset.endpoint || ""
    const turnstileSiteKey = panel.dataset.turnstileSitekey || ""

    let turnstileWidgetId: string | null = null
    let turnstileToken: string | null = null

    const ensureTurnstileWidget = async () => {
      if (!turnstileContainer || !turnstileSiteKey || turnstileWidgetId !== null) return
      await loadTurnstileScript()
      if (!window.turnstile) return
      turnstileWidgetId = window.turnstile.render(turnstileContainer, {
        sitekey: turnstileSiteKey,
        // "invisible" isn't a real Turnstile size (that's reCAPTCHA's API) —
        // whether a challenge is ever shown is controlled by the widget's
        // Widget Mode setting in the Cloudflare dashboard (we use "Managed",
        // which stays invisible for most visitors and only shows a checkbox
        // to ones Cloudflare flags as risky). "flexible" just sizes the
        // widget to its container if a challenge does render.
        size: "flexible",
        callback: (token) => {
          turnstileToken = token
        },
        "expired-callback": () => {
          turnstileToken = null
        },
        "error-callback": () => {
          turnstileToken = null
        },
      })
    }

    // The widget auto-runs on render and calls back with a token once
    // Cloudflare finishes evaluating the visitor (no explicit execute() call
    // needed) — usually near-instant. But Managed mode sometimes decides a
    // visitor needs an interactive checkbox instead of passing silently, and
    // that requires an actual human to notice and click it — a few seconds
    // isn't enough for that, so the timeout here needs to be generous. Each
    // token is single-use, so we hand it out and immediately reset for the
    // next message.
    const TURNSTILE_WAIT_MS = 60_000
    const getTurnstileToken = async (): Promise<string | null> => {
      await ensureTurnstileWidget()
      if (!window.turnstile || turnstileWidgetId === null) return null
      if (turnstileToken) {
        const token = turnstileToken
        turnstileToken = null
        window.turnstile.reset(turnstileWidgetId)
        return token
      }
      return new Promise((resolve) => {
        const deadline = Date.now() + TURNSTILE_WAIT_MS
        const poll = () => {
          if (turnstileToken) {
            const token = turnstileToken
            turnstileToken = null
            window.turnstile?.reset(turnstileWidgetId ?? undefined)
            resolve(token)
          } else if (Date.now() > deadline) {
            resolve(null)
          } else {
            setTimeout(poll, 100)
          }
        }
        poll()
      })
    }

    let anonId = localStorage.getItem(ANON_KEY)
    if (!anonId) {
      anonId =
        typeof crypto !== "undefined" && "randomUUID" in crypto
          ? crypto.randomUUID()
          : String(Date.now())
      localStorage.setItem(ANON_KEY, anonId)
    }

    const load = (): Msg[] => {
      try {
        const raw = localStorage.getItem(LOG_KEY)
        const parsed = raw ? JSON.parse(raw) : []
        return Array.isArray(parsed) ? parsed : []
      } catch {
        return []
      }
    }
    const save = (m: Msg[]) => localStorage.setItem(LOG_KEY, JSON.stringify(m))

    let messages: Msg[] = load()
    let streaming = false

    // User text is shown verbatim (never interpret what a visitor typed as
    // markdown). Assistant text is the model's own output, which does use
    // markdown — render it, but only after html-escaping (see renderMarkdown).
    const setBubbleText = (el: HTMLElement, role: "user" | "assistant", content: string) => {
      if (role === "assistant") {
        el.innerHTML = renderMarkdown(content)
      } else {
        el.textContent = content
      }
    }

    const addBubble = (role: "user" | "assistant", content: string) => {
      const el = document.createElement("div")
      el.className = `chat-msg chat-${role}`

      const label = document.createElement("span")
      label.className = "chat-role"
      label.textContent = role === "user" ? "you" : "assistant"
      el.appendChild(label)

      const text = document.createElement("div")
      text.className = "chat-text"
      setBubbleText(text, role, content)
      el.appendChild(text)

      log.appendChild(el)
      return { bubble: el, text }
    }

    const renderAll = () => {
      log.innerHTML = ""
      if (messages.length === 0) {
        const hint = document.createElement("div")
        hint.className = "chat-hint"
        hint.textContent = GREETING
        log.appendChild(hint)
      } else {
        messages.forEach((m) => addBubble(m.role, m.content))
      }
      log.scrollTop = log.scrollHeight
    }

    const isOpen = () => !panel.hasAttribute("hidden")
    const open = () => {
      panel.removeAttribute("hidden")
      launcher.setAttribute("aria-expanded", "true")
      renderAll()
      requestAnimationFrame(() => input.focus())
      // Start solving as soon as the chat opens, so a token is usually ready
      // by the time the visitor finishes typing their first message.
      void ensureTurnstileWidget()
    }
    const close = () => {
      panel.setAttribute("hidden", "")
      launcher.setAttribute("aria-expanded", "false")
    }

    const autoGrow = () => {
      input.style.height = "auto"
      input.style.height = Math.min(input.scrollHeight, 96) + "px"
    }

    const send = async (raw: string) => {
      const text = raw.trim()
      if (!text || streaming) return

      messages.push({ role: "user", content: text })
      save(messages)
      renderAll()
      input.value = ""
      autoGrow()

      streaming = true
      sendBtn.disabled = true
      const { bubble, text: replyEl } = addBubble("assistant", "")
      bubble.classList.add("is-streaming")
      log.scrollTop = log.scrollHeight

      let acc = ""
      try {
        // Most visitors get a token almost instantly (invisible check). If
        // Cloudflare decides this one needs an interactive checkbox, that
        // requires a human to actually notice and click it — say so instead
        // of silently doing nothing until getTurnstileToken() eventually
        // times out.
        const hintTimer = setTimeout(() => {
          setBubbleText(
            replyEl,
            "assistant",
            "One moment — verifying you're not a bot. If you see a checkbox appear below, go ahead and check it.",
          )
        }, 1500)
        // Note: anonId stays client-side only (localStorage identity for the
        // single-thread UX). It isn't sent to the Worker — a custom header
        // here isn't in the Worker's CORS allow-list and would break the
        // request, and server-side rate limiting keys off the request IP
        // instead, which the client can't spoof.
        const turnstileToken = await getTurnstileToken()
        clearTimeout(hintTimer)
        if (!turnstileToken) throw new Error("verification failed")
        const res = await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ messages, turnstileToken }),
        })
        if (res.status === 429) throw new Error("rate limited")
        if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`)
        const reader = res.body.getReader()
        const decoder = new TextDecoder()
        for (;;) {
          const { done, value } = await reader.read()
          if (done) break
          acc += decoder.decode(value, { stream: true })
          setBubbleText(replyEl, "assistant", acc)
          log.scrollTop = log.scrollHeight
        }
      } catch (err) {
        const message = err instanceof Error ? err.message : ""
        acc =
          acc ||
          (message === "rate limited"
            ? "You've sent a lot of messages — please wait a bit before trying again."
            : message === "verification failed"
              ? "I couldn't verify you're not a bot. Try again in a moment, or reload the page."
              : "Sorry, I couldn't reach the assistant right now. You can email Carlos at larriucarlos@gmail.com.")
        setBubbleText(replyEl, "assistant", acc)
      } finally {
        bubble.classList.remove("is-streaming")
        streaming = false
        sendBtn.disabled = false
        messages.push({ role: "assistant", content: acc })
        save(messages)
        input.focus()
      }
    }

    const clearChat = () => {
      messages = []
      save(messages)
      renderAll()
      input.focus()
    }

    launcher.addEventListener("click", () => (isOpen() ? close() : open()))
    closeBtn?.addEventListener("click", close)
    clearBtn?.addEventListener("click", clearChat)

    form.addEventListener("submit", (e) => {
      e.preventDefault()
      void send(input.value)
    })

    input.addEventListener("input", autoGrow)
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && !e.shiftKey) {
        e.preventDefault()
        void send(input.value)
      }
    })
    panel.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        e.preventDefault()
        close()
      }
    })

    controller = { open, close, toggle: () => (isOpen() ? close() : open()) }
  }

  document.addEventListener("astro:page-load", initChatAgent)
</script>
