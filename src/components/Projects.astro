---
import GitHub from "./icons/GitHub.astro"
import Link from "./icons/Link.astro"
import LinkButton from "./LinkButton.astro"

const TAGS = {
  PYTHON: {
    name: "Python",
    class: "bg-[var(--surface-2)] text-[var(--text)] border border-[var(--border)]",
  },
  DYNACONF: {
    name: "Dynaconf",
    class: "bg-[var(--surface-2)] text-[var(--text)] border border-[var(--border)]",
  },
  GITHUB_ACTIONS: {
    name: "GitHub Actions",
    class: "bg-[var(--surface-2)] text-[var(--text)] border border-[var(--border)]",
  },
  PYDANTIC: {
    name: "Pydantic",
    class: "bg-[var(--surface-2)] text-[var(--text)] border border-[var(--border)]",
  },
  MKDOCS: {
    name: "MkDocs",
    class: "bg-[var(--surface-2)] text-[var(--text)] border border-[var(--border)]",
  },
  AI: {
    name: "AI",
    class: "bg-[var(--surface-2)] text-[var(--text)] border border-[var(--border)]",
  },
  PHP: {
    name: "PHP",
    class: "bg-[var(--surface-2)] text-[var(--text)] border border-[var(--border)]",
  },
  DATABASES: {
    name: "Databases",
    class: "bg-[var(--surface-2)] text-[var(--text)] border border-[var(--border)]",
  },
  OPEN_METEO: {
    name: "Open-Meteo",
    class: "bg-[var(--surface-2)] text-[var(--text)] border border-[var(--border)]",
  },
  CLI: {
    name: "CLI",
    class: "bg-[var(--surface-2)] text-[var(--text)] border border-[var(--border)]",
  },
}

const PROJECTS = [
  {
    title: "Vericlient",
    description:
      "Python interface to consume Veridas APIs. Includes advanced configuration management and automated workflows.",
    github: "https://github.com/clarriu97/vericlient",
    image: "/projects/vericlient.webp",
    imageWidth: 960,
    imageHeight: 720,
    imageAlt: "Vericlient Python library for Veridas APIs",
    tags: [TAGS.PYTHON, TAGS.DYNACONF, TAGS.GITHUB_ACTIONS, TAGS.PYDANTIC, TAGS.MKDOCS],
  },
  {
    title: "weather-tty",
    description:
      "Tiny CLI to print today's weather in your terminal using Open-Meteo, with zero API keys and a clean developer-friendly UX.",
    github: "https://github.com/clarriu97/weather-tty",
    image: "/projects/weather-tty.webp",
    imageWidth: 840,
    imageHeight: 513,
    imageAlt: "weather-tty CLI tool displaying weather in terminal",
    tags: [TAGS.PYTHON, TAGS.OPEN_METEO, TAGS.CLI, TAGS.AI],
  },
  {
    title: "Bachelor's Thesis - Medical Open World",
    description:
      "Developed a full-stack Android app for an NGO to monitor incubators. The app allows medical staff to track the health of babies and manage the incubators remotely.",
    link: "https://medicalopenworld.org/",
    image: "/projects/medical_open_world.webp",
    imageWidth: 960,
    imageHeight: 720,
    imageAlt: "Medical Open World Android app for incubator monitoring",
    tags: [TAGS.PHP, TAGS.DATABASES],
  },
]
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ image, imageWidth, imageHeight, imageAlt, title, description, tags, link, github }) => (
    <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
  <div class="w-full md:w-1/2">
    <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-300 ease-in-out transform overflow-clip rounded-xl border border-[var(--border)] bg-[var(--surface)] md:group-hover:-translate-y-1 md:group-hover:border-[var(--accent-soft)] md:group-hover:shadow-[0_16px_40px_rgba(0,0,0,0.16)]">
      <img alt={imageAlt} class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105" loading="lazy" decoding="async" width={imageWidth} height={imageHeight} src={image} />
    </div>
  </div>

  <div class="w-full md:w-1/2 md:max-w-lg">
    <h3 class="text-2xl font-semibold text-[var(--text)]">
      {title}
    </h3>
    <div class="flex flex-wrap mt-2">
      <ul class="flex flex-row mb-2 gap-x-2">
          {tags.map((tag) => (
            <li>
              <span
                class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
              >
                {tag.name}
              </span>
            </li>
          ))}
        </ul>

      <div class="mt-2 text-[var(--muted)]">{description}</div>
      <footer class="flex items-end justify-start mt-4 gap-x-4">
          {github && (
            <LinkButton href={github}>
              <GitHub class="size-6" />
              GitHub
            </LinkButton>
          )}
          {link && !github && (
            <LinkButton href={link}>
              <Link class="size-4" />
              Preview
            </LinkButton>
          )}
        </footer>
    </div>
  </div>
</article>
    ))
  }
</div>
