---
const personalImageAlt = "Carlos"
import Badge from "@/components/Badge.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import MailIcon from "@/components/icons/Mail.astro"
import SocialPill from "@/components/SocialPill.astro"
---

<div class="max-w-2xl">
  <div class="flex gap-4 mb-4">
    <img
      class="rounded-full ring-1 ring-[var(--border)] size-16"
      src="/clarriu.webp"
      alt={personalImageAlt}
    />
    <a
      href="https://linkedin.com/in/carloslarriu"
      target="_blank"
      rel="noopener"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge>Available for work</Badge>
    </a>
  </div>
  <h1
    class="text-4xl font-semibold tracking-tight sm:text-5xl text-[var(--text)]"
  >
    <span id="typing-text" aria-label="Hello World, I'm Carlos"></span><span class="typing-cursor" aria-hidden="true"></span>
  </h1>

<style>
  .typing-cursor {
    display: inline-block;
    width: 2px;
    height: 1.1em;
    margin-left: 0.08em;
    vertical-align: -0.12em;
    background-color: var(--accent);
    animation: blink-caret 0.75s step-end infinite;
  }

  @keyframes blink-caret {
    from, to { opacity: 1; }
    50% { opacity: 0; }
  }
</style>
  <script>
    let typingInterval: ReturnType<typeof window.setInterval> | null = null;
    let typingTimeout: ReturnType<typeof window.setTimeout> | null = null;

    const initTypingEffect = () => {
      const textNode = document.getElementById("typing-text");
      if (!textNode) return;

      if (typingInterval !== null) window.clearInterval(typingInterval);
      if (typingTimeout !== null) window.clearTimeout(typingTimeout);

      const phrase = "Hello World, I'm Carlos";
      let index = 0;
      let deleting = false;

      const step = () => {
        textNode.textContent = phrase.slice(0, index);

        if (!deleting && index < phrase.length) {
          index += 1;
          return;
        }

        if (!deleting && index === phrase.length) {
          deleting = true;
          if (typingInterval !== null) window.clearInterval(typingInterval);
          typingTimeout = window.setTimeout(() => {
            typingInterval = window.setInterval(step, 55);
          }, 5000);
          return;
        }

        if (deleting && index > 0) {
          index -= 1;
          return;
        }

        if (deleting && index === 0) {
          deleting = false;
          if (typingInterval !== null) window.clearInterval(typingInterval);
          typingTimeout = window.setTimeout(() => {
            typingInterval = window.setInterval(step, 95);
          }, 450);
        }
      };

      typingInterval = window.setInterval(step, 95);
      step();
    };

    document.addEventListener("astro:page-load", initTypingEffect);
  </script>
  <p
    class="mt-6 text-xl text-[var(--muted)] [&>strong]:text-[var(--text)] [&>strong]:font-semibold"
  >
    Building robust backend systems and evolving DevOps processes, with AI as a constant source of inspiration.
  </p>
  <p
    class="mt-6 text-xl text-[var(--muted)] [&>strong]:text-[var(--text)] [&>strong]:font-semibold"
  >
    <strong>Software Engineer</strong> from Pamplona 🇪🇸 currently based in Dubai 🇦🇪
  </p>
  <p
    class="mt-6 text-xl text-[var(--muted)] [&>strong]:text-[var(--text)] [&>strong]:font-semibold"
  >
    Specializing in building reliable, scalable, and efficient digital infrastructures.
  </p>
  <nav class="flex flex-wrap gap-4 mt-8">
    <SocialPill href="mailto:larriucarlos@gmail.com">
      <MailIcon class="size-4" />
      Contact me
    </SocialPill>
    <SocialPill href="https://linkedin.com/in/carloslarriu">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
  </nav>
</div>
