---
const personalImageAlt = "Carlos"
import Badge from "@/components/Badge.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import MailIcon from "@/components/icons/Mail.astro"
import SocialPill from "@/components/SocialPill.astro"
---

<div class="max-w-2xl">
  <div class="flex gap-4 mb-4">
    <img
      class="rounded-full ring-1 ring-[var(--border)] size-16"
      src="/clarriu.webp"
      alt={personalImageAlt}
    />
    <a
      href="https://linkedin.com/in/carloslarriu"
      target="_blank"
      rel="noopener"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge>Available for work</Badge>
    </a>
  </div>
  <div class="terminal mt-2">
    <div class="terminal-bar" aria-hidden="true">
      <span class="dot dot-red"></span>
      <span class="dot dot-amber"></span>
      <span class="dot dot-green"></span>
      <span class="terminal-title font-mono">visitor@larri.dev: ~</span>
    </div>
    <div class="terminal-body font-mono">
      <p class="term-line" aria-hidden="true">
        <span class="prompt"
          ><span class="prompt-user">visitor@larri.dev</span><span
            class="prompt-path">:~$</span
          ></span
        > <span class="term-cmd">whoami</span>
      </p>
      <h1 class="term-name" aria-label="Hello World, I'm Carlos">
        <span id="decode-name" class="has-cursor" aria-hidden="true"></span>
      </h1>
      <p id="term-line2" class="term-line term-hidden" aria-hidden="true">
        <span class="prompt"
          ><span class="prompt-user">visitor@larri.dev</span><span
            class="prompt-path">:~$</span
          ></span
        > <span id="decode-cmd" class="term-cmd"></span>
      </p>
      <p id="decode-role" class="term-role term-hidden" aria-hidden="true"></p>
    </div>
  </div>

<style>
  .terminal {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    box-shadow: 0 24px 60px -28px rgba(0, 0, 0, 0.55);
    overflow: hidden;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 0.85rem;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface-2) 55%, transparent);
  }

  .dot {
    display: inline-block;
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 9999px;
  }
  .dot-red { background: #ff5f57; }
  .dot-amber { background: #febc2e; }
  .dot-green { background: #28c840; }

  .terminal-title {
    margin-left: 0.4rem;
    font-size: 0.78rem;
    color: var(--muted);
  }

  .terminal-body {
    padding: 1.1rem 1.25rem 1.35rem;
    font-size: clamp(0.85rem, 2.6vw, 0.95rem);
    line-height: 1.7;
  }

  .term-line {
    margin: 0;
    color: var(--muted);
    white-space: pre-wrap;
    word-break: break-word;
  }

  .prompt {
    user-select: none;
  }
  .prompt-user { color: var(--accent); }
  .prompt-path { color: var(--muted); }
  .term-cmd { color: var(--text); }

  .term-name {
    margin: 0.4rem 0;
    font-size: clamp(1.55rem, 6vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.15;
    color: var(--text);
    min-height: 1.2em;
    word-break: break-word;
  }

  .term-role {
    margin: 0.15rem 0 0;
    color: var(--accent);
    word-break: break-word;
  }

  .term-hidden { opacity: 0; }
  .term-reveal { opacity: 1; transition: opacity 0.45s ease; }

  .has-cursor::after {
    content: "";
    display: inline-block;
    width: 0.55ch;
    height: 1.05em;
    margin-left: 0.12em;
    vertical-align: -0.18em;
    background-color: var(--accent);
    box-shadow: 0 0 9px var(--accent);
    animation: blink-caret 1s step-end infinite;
  }

  @keyframes blink-caret {
    from, to { opacity: 1; }
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .has-cursor::after { animation: none; }
  }
</style>
  <script>
    const timers: Array<ReturnType<typeof setTimeout>> = [];
    const clearTimers = () => {
      timers.forEach((t) => clearTimeout(t));
      timers.length = 0;
    };

    const CHARS =
      "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!<>-_\\/[]{}=+*?#$";
    const rand = () => CHARS[Math.floor(Math.random() * CHARS.length)];

    const initHeroTerminal = () => {
      const nameEl = document.getElementById("decode-name");
      const cmdEl = document.getElementById("decode-cmd");
      const roleEl = document.getElementById("decode-role");
      const line2El = document.getElementById("term-line2");
      if (!nameEl || !cmdEl || !roleEl || !line2El) return;

      clearTimers();

      const NAME = "Hello World, I'm Carlos";
      const CMD = "cat ~/stack.txt";
      const ROLE = "Python · FastAPI · Docker · CI/CD · AI";

      // Reset to the initial state (handles re-runs on client navigation).
      nameEl.textContent = "";
      cmdEl.textContent = "";
      roleEl.textContent = "";
      nameEl.classList.add("has-cursor");
      roleEl.classList.remove("has-cursor");
      line2El.classList.remove("has-cursor");
      line2El.className = "term-line term-hidden";
      roleEl.className = "term-role term-hidden";

      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (reduceMotion) {
        nameEl.textContent = NAME;
        cmdEl.textContent = CMD;
        roleEl.textContent = ROLE;
        line2El.className = "term-line term-reveal";
        roleEl.className = "term-role term-reveal has-cursor";
        nameEl.classList.remove("has-cursor");
        return;
      }

      // Lock characters left→right while scrambling the rest.
      const decode = (
        el: HTMLElement,
        text: string,
        msPerChar: number,
        done?: () => void
      ) => {
        const start = performance.now();
        const tick = () => {
          const revealed = Math.floor((performance.now() - start) / msPerChar);
          let out = "";
          for (let i = 0; i < text.length; i++) {
            if (text[i] === " ") {
              out += " ";
            } else {
              out += i < revealed ? text[i] : rand();
            }
          }
          el.textContent = out;
          if (revealed >= text.length) {
            el.textContent = text;
            done?.();
            return;
          }
          timers.push(setTimeout(tick, 38));
        };
        tick();
      };

      const type = (
        el: HTMLElement,
        text: string,
        msPerChar: number,
        done?: () => void
      ) => {
        let i = 0;
        const tick = () => {
          i += 1;
          el.textContent = text.slice(0, i);
          if (i >= text.length) {
            done?.();
            return;
          }
          timers.push(setTimeout(tick, msPerChar));
        };
        tick();
      };

      // Flip a random glyph now and then so the line feels "alive".
      const microGlitch = (el: HTMLElement, text: string) => {
        const loop = () => {
          const i = Math.floor(Math.random() * text.length);
          if (text[i] !== " ") {
            const chars = text.split("");
            chars[i] = rand();
            el.textContent = chars.join("");
            timers.push(setTimeout(() => (el.textContent = text), 55));
          }
          timers.push(setTimeout(loop, 2400 + Math.random() * 2800));
        };
        timers.push(setTimeout(loop, 3200));
      };

      decode(nameEl, NAME, 55, () => {
        microGlitch(nameEl, NAME);
        timers.push(
          setTimeout(() => {
            nameEl.classList.remove("has-cursor");
            line2El.className = "term-line term-reveal has-cursor";
            type(cmdEl, CMD, 58, () => {
              line2El.classList.remove("has-cursor");
              timers.push(
                setTimeout(() => {
                  roleEl.className = "term-role term-reveal has-cursor";
                  decode(roleEl, ROLE, 28);
                }, 220)
              );
            });
          }, 520)
        );
      });
    };

    document.addEventListener("astro:page-load", initHeroTerminal);
  </script>
  <p
    class="mt-6 text-xl text-[var(--muted)] [&>strong]:text-[var(--text)] [&>strong]:font-semibold"
  >
    Building production AI backends that actually ship. Working with the business to decide which AI is worth building, and keeping a human touch in the middle of it.
  </p>
  <p
    class="mt-6 text-xl text-[var(--muted)] [&>strong]:text-[var(--text)] [&>strong]:font-semibold"
  >
    <strong>Software Engineer</strong> from Pamplona 🇪🇸 currently based in Dubai 🇦🇪
  </p>
  <p
    class="mt-6 text-xl text-[var(--muted)] [&>strong]:text-[var(--text)] [&>strong]:font-semibold"
  >
    Focused on scalable backend systems and production-grade AI.
  </p>
  <nav class="flex flex-wrap gap-4 mt-8">
    <a
      href="/#blog"
      class="inline-flex items-center justify-center gap-2 px-4 py-1.5 transition-colors border rounded-full text-[var(--text)] bg-[var(--surface)] border-[var(--border)] text-md hover:bg-[var(--surface-2)] hover:border-[var(--accent-soft)] hover:text-[var(--text)] group max-w-fit focus:outline-none focus-visible:outline-none focus-visible:ring focus-visible:ring-[var(--accent)]/40 focus-visible:ring-offset-2"
    >
      Writing
    </a>
    <SocialPill href="mailto:larriucarlos@gmail.com">
      <MailIcon class="size-4" />
      Contact me
    </SocialPill>
    <SocialPill href="https://linkedin.com/in/carloslarriu">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
  </nav>
</div>
