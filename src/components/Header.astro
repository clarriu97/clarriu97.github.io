---
import ThemeToggle from "./ThemeToggle.astro"

const navItems = [
  {
    title: "Home",
    label: "home",
    url: "/",
  },
  {
    title: "Experience",
    label: "experience",
    url: "/#experience",
  },
  {
    title: "Projects",
    label: "projects",
    url: "/#projects",
  },
  {
    title: "About",
    label: "about-me",
    url: "/#about-me",
  },
  {
    title: "Contact",
    label: "contact",
    url: "mailto:larriucarlos@gmail.com",
  },
]
---

<header
  class="fixed top-0 z-10 flex items-center justify-center w-full mx-auto mt-2"
>
  <nav
    id="header-nav"
    class="flex flex-wrap items-center justify-center gap-x-0 gap-y-1 px-3 text-sm font-medium rounded-full text-[var(--muted)] max-w-[min(100vw-1rem,42rem)]"
  >
    {
      navItems.map((link) => (
        <a
          class="relative block px-2 py-2 transition-colors duration-200 hover:text-[var(--text)]"
          aria-label={link.label}
          href={link.url}
        >
          {link.title}
        </a>
      ))
    }
    <ThemeToggle />
  </nav>
</header>

<script>
  import { initHeaderScrollSpy } from "@/lib/headerScrollSpy"

  let scrollSpyCleanup: (() => void) | null = null

  document.addEventListener("astro:page-load", () => {
    if (scrollSpyCleanup) {
      scrollSpyCleanup()
      scrollSpyCleanup = null
    }

    const path = window.location.pathname
    if (path !== "/" && path !== "") return

    scrollSpyCleanup = initHeaderScrollSpy()
  })
</script>

<style>
  nav {
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    border: 1px solid var(--border);
    backdrop-filter: blur(10px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
    animation: nav-shadow 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  a.active-link {
    color: var(--accent);
  }

  @keyframes nav-shadow {
    0% {
      background: transparent;
      border-color: transparent;
      box-shadow: none;
    }
    to {
      background: color-mix(in srgb, var(--surface) 70%, transparent);
      border-color: var(--border);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.14);
    }
  }
</style>
